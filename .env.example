# ================================================
# FOXTAFFY.GAY — Пример конфигурации
# Скопируйте в .env и заполните своими значениями
# ВАЖНО: не добавляйте кавычки вокруг значений!
# Правильно:   ADMIN_SECRET_CODE=mysecretpassword
# Неправильно: ADMIN_SECRET_CODE="mysecretpassword"
# ================================================

# ── PostgreSQL ─────────────────────────────────
POSTGRES_USER=foxtaffy
POSTGRES_PASSWORD=changeme
POSTGRES_DB=foxtaffy
PGRST_DB_PASS=changeme

# ── MinIO ──────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme

# ── PostgREST ──────────────────────────────────
PGRST_JWT_SECRET=changeme_long_secret_at_least_32_chars

# ── Upload API ─────────────────────────────────
UPLOAD_API_KEY=changeme_api_key

# Секретный код для входа в админ-панель (без кавычек!)
ADMIN_SECRET_CODE=changeme_admin_code

# Секрет для подписи сессионных токенов (опционально, по умолчанию PGRST_JWT_SECRET)
ADMIN_SESSION_SECRET=

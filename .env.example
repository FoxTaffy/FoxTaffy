# ================================================
# FOXTAFFY.GAY — Переменные окружения
# Скопируй этот файл в .env и заполни значения
# НИКОГДА не коммить .env в репозиторий!
# ================================================

# ── Серверный пароль админки ────────────────────
# НЕ используй префикс VITE_, иначе секрет попадёт в браузерный бандл
ADMIN_SECRET_CODE=ЗАМЕНИ_НА_СЛОЖНЫЙ_ПАРОЛЬ
ADMIN_SESSION_SECRET=ЗАМЕНИ_НА_ОТДЕЛЬНЫЙ_СЕКРЕТ_ДЛЯ_COOKIE

# ── MinIO (S3-хранилище) ─────────────────────────
# Публичный URL через nginx-прокси (без trailing slash)
VITE_MINIO_PUBLIC_URL=/s3
# Upload API endpoint
VITE_UPLOAD_API_URL=/upload
# Серверный API-ключ для скриптов/миграций. НЕ используй VITE_
UPLOAD_API_KEY=ЗАМЕНИ_НА_API_КЛЮЧ

# ── Supabase (если используется как бэкап) ───────
# Если мигрировал на self-hosted PostgREST — заполнять не нужно
VITE_SUPABASE_URL=https://ТВОЙ_ПРОЕКТ.supabase.co
VITE_SUPABASE_ANON_KEY=ЗАМЕНИ_НА_ANON_KEY

# ── PostgREST (self-hosted) ──────────────────────
# URL к PostgREST API (обычно через nginx /api/)
VITE_POSTGREST_URL=/api
PGRST_JWT_SECRET=ЗАМЕНИ_НА_JWT_СЕКРЕТ
